{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      "engines": {
        "node": ">=16"
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyLimit": 5,
    "runtime": {
      "type": "ZONE",
      "zone": "AUTO"
    }
  }
}
