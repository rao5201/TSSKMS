{
  "name": "teahaixin-mirror-soul",
  "version": "1.0.4",
  "description": "茶海虾王·镜心 - 情绪社交平台桌面客户端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "cd desktop && electron-builder --win --x64",
    "pack": "cd desktop && electron-builder --dir"
  },
  "author": "海南茶海虾王管理有限责任公司",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.teahaixin.mirrorsoul",
    "productName": "茶海虾王镜心",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ]
  }
}